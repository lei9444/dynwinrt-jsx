{
  "name": "dynwinrt-jsx-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Native WinUI 3 dashboard built with dynwinrt-jsx.",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "build:codegen": "cargo build --release -p dynwinrt-codegen --manifest-path ../../../dynwinrt/Cargo.toml",
    "setup": "npm run build:codegen && winapp restore",
    "generate": "winapp node generate-bindings",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "imports": {
    "#winapp/bindings": {
      "types": "./.winapp/bindings/index.d.ts",
      "require": "./.winapp/bindings/index.js",
      "default": "./.winapp/bindings/index.js"
    }
  },
  "dependencies": {
    "@microsoft/dynwinrt": "file:../../../dynwinrt/bindings/js",
    "dynwinrt-jsx": "file:../.."
  },
  "devDependencies": {
    "@microsoft/dynwinrt-codegen": "file:tools/local-codegen",
    "@microsoft/winappcli": "file:../../../winappCli/src/winapp-npm",
    "typescript": "5.9.2"
  },
  "winapp": {
    "jsBindings": {
      "additionalWinmds": [
        {
          "namespace": "Windows.Foundation",
          "classes": [
            "PropertyValue"
          ]
        },
        {
          "namespace": "Microsoft.UI.Windowing",
          "classes": [
            "AppWindow"
          ]
        },
        {
          "namespace": "Microsoft.UI.Xaml",
          "classes": [
            "Application",
            "Window"
          ]
        },
        {
          "namespace": "Microsoft.UI.Xaml.Automation",
          "classes": [
            "AutomationProperties"
          ]
        },
        {
          "namespace": "Microsoft.UI.Xaml.Controls",
          "classes": [
            "Border",
            "Button",
            "CheckBox",
            "Grid",
            "ProgressBar",
            "ScrollViewer",
            "StackPanel",
            "TextBlock",
            "TextBox",
            "ToggleSwitch"
          ]
        },
        {
          "namespace": "Microsoft.UI.Xaml.Media",
          "classes": [
            "MicaBackdrop",
            "SolidColorBrush"
          ]
        }
      ]
    }
  }
}
