{
  "name": "dynwinrt-jsx",
  "version": "1.0.0",
  "description": "Type-safe declarative JSX runtime for native WinUI 3 controls projected by dynwinrt.",
  "license": "MIT",
  "author": "leileizhang",
  "repository": {
    "type": "git",
    "url": "https://github.com/lei9444/dynwinrt-jsx.git"
  },
  "keywords": [
    "dynwinrt",
    "jsx",
    "native",
    "typescript",
    "windows",
    "winrt",
    "winui"
  ],
  "os": [
    "win32"
  ],
  "bin": {
    "dynwinrt-jsx": "./bin/create.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "require": "./dist/jsx-runtime.js",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "require": "./dist/jsx-dev-runtime.js",
      "default": "./dist/jsx-dev-runtime.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "npm run build && node --test tests/*.test.js",
    "check": "npm run typecheck && npm test",
    "prepack": "npm run check"
  },
  "devDependencies": {
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
